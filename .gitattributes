# 强制行尾与文本属性，避免 Windows/Linux 跨平台 CRLF 漂移

*           text=auto eol=lf

*.go        text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
Makefile    text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf

# Windows 脚本保留 CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# 二进制，不做转换
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
