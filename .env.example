# api-gateway 环境变量示例（请复制为 .env.local 后修改使用）
#
# 加载顺序：默认值 → .env.local（若存在）→ 进程环境变量（最终胜出）。
# 命名约定：键名全大写 + 下划线，加载时 koanf 会自动小写映射。
#
# !!! 重要：本文件仅作示例，提交到 Git。
#     真实凭据/密钥写到 .env.local（已被 .gitignore 忽略），勿提交真实值。

#####################################
# HTTP 服务
#####################################
# Gin HTTP 监听地址，格式 ":port" 或 "host:port"，默认 :8080
HTTP_ADDR=:8080

#####################################
# 日志
#####################################
# slog 日志等级：debug | info | warn | error，默认 info
LOG_LEVEL=info

#####################################
# 数据库（必填）
#####################################
# PostgreSQL 连接串（DSN），**必填**，缺失会 fail-fast 退出
# 示例：postgres://user:password@127.0.0.1:5432/api_gateway?sslmode=disable
# 勿提交真实值
PG_DSN=

#####################################
# Redis（用于 Asynq 队列 / 缓存）
#####################################
# Redis 连接地址，默认 localhost:6379
REDIS_ADDR=localhost:6379

#####################################
# 信封加密主密钥（必填）
#####################################
# GATEWAY_KEK_V1 是信封加密 v1 版本的主密钥（KEK），用于解密 provider 凭据。
# P0 阶段用环境变量明文传入；P1+ 接 KMS。
# 内容约定：32 字节随机数据，base64 标准编码后填入；解码后字节数必须为 32（AES-256）。
# 生成方法（Linux/Mac）：openssl rand -base64 32
# 生成方法（Windows PowerShell）：
#   [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# **勿提交真实值**
GATEWAY_KEK_V1=

#####################################
# Admin Token 签名密钥（必填）
#####################################
# 用于签发 / 校验 Admin API Bearer Token 的 HMAC 密钥（建议 >=32 字节随机串）。
# **勿提交真实值**
ADMIN_TOKEN_SIGNING_KEY=

#####################################
# 可观测性 — OpenTelemetry
#####################################
# OTel trace exporter 类型，枚举：stdout | otlp，默认 stdout
# stdout：开发环境，trace 写入进程 stdout
# otlp：生产环境，需要额外配置 OTEL_EXPORTER_OTLP_ENDPOINT 等
OTEL_EXPORTER=stdout

#####################################
# CORS
#####################################
# 允许跨域的 origin 白名单，逗号分隔（含 scheme）。
# 空值 = 拒绝所有跨域（fail-closed 默认）。
# 示例：CORS_ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

#####################################
# 部署环境模式
#####################################
# GATEWAY_ENV：production | dev | test，默认 dev。
# production 模式额外强制：TRUSTED_PROXIES + TLS（或 FRONT_TLS_ACK）+ 审计 Tier1 路径 +
#   relay 上游 base_url 必须 https。dev / test 放宽这些约束（便于本地 mock）。
GATEWAY_ENV=dev

#####################################
# Token / Key HMAC pepper（必填，全环境强制）
#####################################
# GATEWAY_TOKEN_PEPPER：admin token 与 business key 共享的 HMAC pepper。
# 输入为 hex 或 base64 编码，解码后必须 >= 32 字节，否则 fail-fast 拒启动。
# 生成方法：openssl rand -hex 32
# **勿提交真实值**
GATEWAY_TOKEN_PEPPER=

#####################################
# Relay 业务路由 /v1（F-min；接入上游 provider 时配置）
#####################################
# GATEWAY_RELAY_ENABLED=true 才注册 /v1/chat/completions 业务路由；
# 默认 false（admin-only 部署，调 /v1 返 404）。
# =true 时以下 8 个字段全部必填，任一非法/缺失 → 进程 fail-fast 拒启动。
GATEWAY_RELAY_ENABLED=false
# 业务可见 model 名（业务请求 body 里的 model 字段；MVP 单条字典传任何值都路由到此条）
GATEWAY_RELAY_MODEL_NAME=gw-default
# provider 协议簇；MVP 唯一合法值 openai_compat
GATEWAY_RELAY_UPSTREAM_PROVIDER_TYPE=openai_compat
# 上游 base url（不含 /chat/completions）；production 强制 https。
# 火山引擎 ARK 示例：https://ark.cn-beijing.volces.com/api/v3
GATEWAY_RELAY_UPSTREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 上游凭据（MVP env 明文；P1 envelope encryption）。**勿提交真实值**
GATEWAY_RELAY_UPSTREAM_API_KEY=
# 上游真实 model 名（火山 ARK 豆包示例）
GATEWAY_RELAY_UPSTREAM_MODEL_NAME=doubao-1-5-pro-32k-250115
# input / output token 单价：每 1M token 的 CNY 分数（800 = ¥8/M，2000 = ¥20/M）
GATEWAY_RELAY_PRICE_INPUT_PER_1M_MINOR=800
GATEWAY_RELAY_PRICE_OUTPUT_PER_1M_MINOR=2000
# 字典默认 max context tokens（业务可在请求中传更小的 max_tokens）；范围 [1, 1000000]
GATEWAY_RELAY_MAX_CONTEXT_TOKENS=32768
